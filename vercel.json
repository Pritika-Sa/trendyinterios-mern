{
  "version": 2,
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "./client/build",
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "PORT": "5000",
    "NODE_ENV": "production",
    "CLIENT_ORIGIN": "@client_origin"
  },
  "functions": {
    "server/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    }
  ]
}
