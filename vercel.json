{
  "version": 2,
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "./client/build",
  "env": {
    "PORT": "5000",
    "NODE_ENV": "production"
  },
  "functions": {
    "server/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    }
  ]
}
