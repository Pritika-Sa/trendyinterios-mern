# Root .env example file structure for reference
# This shows what environment variables should be configured

# Server Environment Variables (see server/.env.example)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/trendyinterios?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=production
CLIENT_ORIGIN=https://your-domain.vercel.app
PORT=5000

# Client Environment Variables (see client/.env.example)
REACT_APP_API_URL=https://your-domain.vercel.app
